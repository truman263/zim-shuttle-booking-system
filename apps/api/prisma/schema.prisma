generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  DRIVER
  FINANCE
  CUSTOMER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  VEHICLE_ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ECOCASH
  ONEMONEY
  INNBUCKS
  VISA
  MASTERCARD
  PAYNOW
}

enum VehicleStatus {
  AVAILABLE
  BOOKED
  IN_SERVICE
  MAINTENANCE
  INACTIVE
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  INACTIVE
}

enum TripType {
  AIRPORT_TRANSFER
  CITY_TO_CITY
  PRIVATE_HIRE
  CORPORATE_TRANSPORT
  EVENT_TRANSPORT
  TOURISM
  SCHOOL_TRANSPORT
  CAR_RENTAL
  CUSTOM
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  email     String?
  phone     String?
  whatsapp  String?
  address   String?
  logoUrl   String?
  status    CompanyStatus @default(TRIAL)

  users     User[]
  customers Customer[]
  drivers   Driver[]
  vehicles  Vehicle[]
  routes    Route[]
  bookings  Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  fullName  String
  email     String   @unique
  phone     String?
  password  String
  role      UserRole @default(CUSTOMER)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  fullName  String
  phone     String
  email     String?
  nationalId String?
  address   String?

  bookings  Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])

  fullName      String
  phone         String
  email         String?
  licenseNumber String?
  status        DriverStatus @default(AVAILABLE)

  bookings      Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Vehicle {
  id                String        @id @default(cuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])

  name              String
  registrationNo    String
  vehicleType       String
  passengerCapacity Int
  luggageCapacity   String?
  status            VehicleStatus @default(AVAILABLE)
  imageUrl           String?

  bookings          Booking[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Route {
  id              String  @id @default(cuid())
  companyId       String
  company         Company @relation(fields: [companyId], references: [id])

  name            String
  pickupCity      String
  destinationCity String
  basePrice       Decimal
  isActive        Boolean @default(true)

  bookings        Booking[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Booking {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])

  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])

  routeId         String?
  route           Route?        @relation(fields: [routeId], references: [id])

  driverId        String?
  driver          Driver?       @relation(fields: [driverId], references: [id])

  vehicleId       String?
  vehicle         Vehicle?      @relation(fields: [vehicleId], references: [id])

  bookingRef      String        @unique
  tripType        TripType
  pickupLocation  String
  destination     String
  pickupDate      DateTime
  passengers      Int
  luggageDetails  String?
  specialNotes    String?

  estimatedPrice  Decimal?
  finalPrice      Decimal?
  depositAmount   Decimal?

  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)

  payments        Payment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id             String        @id @default(cuid())

  bookingId      String
  booking        Booking       @relation(fields: [bookingId], references: [id])

  amount         Decimal
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  transactionRef String?
  paidAt         DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}