generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  DRIVER
  FINANCE
  CUSTOMER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  VEHICLE_ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ECOCASH
  ONEMONEY
  INNBUCKS
  VISA
  MASTERCARD
  PAYNOW
}

enum VehicleStatus {
  AVAILABLE
  BOOKED
  IN_SERVICE
  MAINTENANCE
  INACTIVE
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  INACTIVE
}

enum TripType {
  AIRPORT_TRANSFER
  CITY_TO_CITY
  PRIVATE_HIRE
  CORPORATE_TRANSPORT
  EVENT_TRANSPORT
  TOURISM
  SCHOOL_TRANSPORT
  CAR_RENTAL
  CUSTOM
}

enum RouteType {
  CITY_TO_CITY
  AIRPORT_TRANSFER
  LOCAL_TRANSFER
  PRIVATE_HIRE
  TOUR_PACKAGE
  CORPORATE_TRANSFER
  CUSTOM
}

enum PricingMode {
  FIXED_ROUTE
  DISTANCE_BASED
  HOURLY
  DAILY
  CUSTOM_QUOTE
}

enum PriceUnit {
  PER_PASSENGER
  PER_TRIP
  PER_KM
  PER_HOUR
  PER_DAY
}

enum RoadCondition {
  GOOD
  AVERAGE
  BAD
  RURAL
  MIXED
}

enum ZoneType {
  CBD
  AIRPORT
  SUBURBAN
  RURAL
  TOURIST_AREA
  BORDER
  BAD_ROAD_AREA
  HIGH_DEMAND_AREA
  CUSTOM
}

enum AdjustmentType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum PricingRuleType {
  DISTANCE_BAND
  ROAD_CONDITION
  ZONE_SURCHARGE
  VEHICLE_TYPE
  TRIP_TYPE
  TIME_BASED
  CUSTOM
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  email     String?
  phone     String?
  whatsapp  String?
  address   String?
  logoUrl   String?
  status    CompanyStatus @default(TRIAL)

  users        User[]
  customers    Customer[]
  drivers      Driver[]
  vehicles     Vehicle[]
  routes       Route[]
  bookings     Booking[]
  zones        Zone[]
  pricingRules PricingRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  fullName  String
  email     String   @unique
  phone     String?
  password  String
  role      UserRole @default(CUSTOMER)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  fullName   String
  phone      String
  email      String?
  nationalId String?
  address    String?

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  fullName      String
  phone         String
  email         String?
  licenseNumber String?
  status        DriverStatus @default(AVAILABLE)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name              String
  registrationNo    String
  vehicleType       String
  passengerCapacity Int
  luggageCapacity   String?
  status            VehicleStatus @default(AVAILABLE)
  imageUrl          String?

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name            String
  pickupCity      String
  destinationCity String
  basePrice       Decimal
  isActive        Boolean @default(true)

  routeType                RouteType     @default(CITY_TO_CITY)
  pricingMode              PricingMode   @default(FIXED_ROUTE)
  priceUnit                PriceUnit     @default(PER_PASSENGER)
  distanceKm               Decimal?
  estimatedDurationMinutes Int?
  roadCondition            RoadCondition @default(GOOD)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Zone {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name            String
  zoneType        ZoneType       @default(CUSTOM)
  description     String?
  adjustmentType  AdjustmentType @default(FIXED_AMOUNT)
  adjustmentValue Decimal        @default(0)
  roadCondition   RoadCondition?
  isActive        Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRule {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String
  ruleType    PricingRuleType
  pricingMode PricingMode?
  routeType   RouteType?
  priceUnit   PriceUnit?

  minDistanceKm Decimal?
  maxDistanceKm Decimal?

  vehicleType   String?
  roadCondition RoadCondition?
  zoneType      ZoneType?

  adjustmentType AdjustmentType @default(FIXED_AMOUNT)
  amount         Decimal?
  percentage     Decimal?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  routeId String?
  route   Route? @relation(fields: [routeId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  bookingRef     String   @unique
  tripType       TripType
  customTripType String?

  pickupLocation String
  destination    String
  pickupDate     DateTime
  dropoffDate    DateTime?
  durationHours  Decimal?
  durationDays   Decimal?
  passengers     Int

  luggageDetails String?
  specialNotes   String?

  estimatedPrice Decimal?
  finalPrice     Decimal?
  depositAmount  Decimal?

  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  amount         Decimal
  method         PaymentMethod
  status         PaymentStatus @default(UNPAID)
  transactionRef String?
  paidAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}